{
  "name": "swimfo-server",
  "version": "1.0.0",
  "private": true,
  "description": "Proxy server for Swimfo watch app — aggregates weather and tide APIs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "debug": "node dist/debug.js",
    "debug-tide": "node dist/debug-tide.js",
    "list-remote-locations": "node dist/list-remote-locations.js",
    "check-response": "node dist/check-response.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
